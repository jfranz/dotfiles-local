theme = TokyoNight Moon
unfocused-split-opacity = 0.65

# Split creation (Cmd+Shift+h/j/k/l)
keybind = cmd+shift+h=new_split:left
keybind = cmd+shift+j=new_split:down
keybind = cmd+shift+k=new_split:up
keybind = cmd+shift+l=new_split:right

# Split resizing (Cmd+Ctrl+Arrow)
keybind = cmd+ctrl+left=resize_split:left,40
keybind = cmd+ctrl+down=resize_split:down,40
keybind = cmd+ctrl+up=resize_split:up,40
keybind = cmd+ctrl+right=resize_split:right,40

# Tab management
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
