#!/bin/sh

brew bundle --file=- <<EOF
brew "bat"
brew "fd"
brew "ffmpeg"
brew "fzf"
brew "glow"
brew "jq"
brew "lazygit"
brew "ripgrep"
brew "wget"
brew "yazi"
brew "zoxide"
EOF

fancy_echo "Cleaning up old Homebrew formulae ..."
brew cleanup

if [ -r "$HOME/.rcrc" ]; then
  fancy_echo "Updating dotfiles ..."
  rcup
fi
